{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Deploy Plugin (Debug Local)",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"Debug-Local.bat"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Package Release Zip",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"package-release.ps1"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}